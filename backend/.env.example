# Google OAuth 2.0 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# JWT secret (any random string)
JWT_SECRET=change-this-to-a-random-secret-key

# AWS credentials (IAM user with Textract permissions)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# OpenAI API key
OPENAI_API_KEY=your-openai-api-key

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Public URL for Google Drive webhook notifications
# In local dev, use ngrok: ngrok http 8000 → use the https URL
WEBHOOK_BASE_URL=https://your-public-url.ngrok-free.app
